#Inicializacion de Pygame
pygame.init()

tamannio_celdas = 50

#Definicion de colores
WHITE = (255, 255, 255)
BLACK = (0, 0, 0)
GREEN = (0, 255, 0)
RED = (255,0, 0)
BLUE = (0,0,255)

#Creacion de la pantalla y dibujar el laberinto
screen = pygame.display.set_mode((columnas * tamannio_celdas, filas * tamannio_celdas))
pygame.display.set_caption("Mapa")

#Dibujar el labetinto en la pantalla
def draw_mapa():
    for row in range(len(mapa)):
        for col in range(len(mapa[0])):
            CELDA = mapa[row][col]

            if CELDA == '#':
                color = BLACK
            
            elif CELDA == 'T':
                color = GREEN
            
            elif CELDA == '.':
                color = WHITE
            
            elif CELDA == '*':
                color = RED

            pygame.draw.rect(screen, color, (col*tamannio_celdas, row * tamannio_celdas, tamannio_celdas, tamannio_celdas))
#Bucle principal


def main():
    global running
    running = True

    while running:
        for event in pygame.event.get():
            if event.type == pygame.QUIT:
                running = False
        
        screen.fill(WHITE)
        draw_mapa()
        pygame.display.flip()
    
    pygame.quit()


resolver_mapa()

if __name__ == "__main__":
    main()